# Telegram
TG_API_ID=your_api_id
TG_API_HASH=your_api_hash
TG_SESSION=bridge_session

# VK
VK_TOKEN=your_vk_bot_token
VK_GROUP_ID=your_vk_group_id

# VK user ID куда слать уведомления
VK_TARGET_USER_ID=your_vk_user_id

# === Опционально ===

# Telegram proxy (опционально)
# TG_PROXY=socks5://127.0.0.1:1080

# Логирование
LOG_LEVEL=INFO
LOG_FILE=bridge.log

# База данных
DB_PATH=bridge.db

# Фильтры чатов (id через запятую)
# CHAT_FILTERS_WHITELIST=123,456
# CHAT_FILTERS_BLACKLIST=789

# Какие типы чатов форвардить (1=да, 0=нет)
FORWARD_DMS=1
FORWARD_CHANNELS=1
FORWARD_GROUPS=1

# Лимиты
MAX_MEDIA_SIZE_MB=50
BRIDGE_QUEUE_SIZE=100

# VK Long Poll
VK_POLL_WAIT=25
